<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sabiduría Diaria - Dual Version</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f8fafc;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .serif {
            font-family: 'Playfair Display', serif;
        }
        .card-shadow {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        }
        .fade-in {
            animation: fadeIn 0.8s ease-out forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-4xl w-full">
        <!-- Fecha y Encabezado -->
        <div class="text-center mb-10 fade-in">
            <h1 id="fecha-actual" class="text-gray-500 font-medium tracking-widest uppercase text-xs mb-2 italic">
                Cargando fecha...
            </h1>
            <h2 class="text-3xl font-bold text-slate-800 tracking-tight">Proverbio del Día 📖</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Columna RVR 1960 -->
            <div class="bg-white rounded-3xl p-8 card-shadow border border-slate-100 flex flex-col fade-in" style="animation-delay: 0.2s">
                <div class="mb-6">
                    <span class="px-3 py-1 bg-amber-50 text-amber-700 text-[10px] font-bold rounded-full uppercase tracking-wider">
                        Reina-Valera 1960
                    </span>
                </div>
                <div class="flex-grow">
                    <p id="texto-rvr" class="serif text-xl text-slate-700 leading-relaxed italic">
                        "..."
                    </p>
                </div>
                <div class="mt-8 pt-6 border-t border-slate-50">
                    <p id="cita-rvr" class="font-bold text-slate-400 text-sm tracking-widest uppercase">
                        -
                    </p>
                </div>
            </div>

            <!-- Columna NTV -->
            <div class="bg-white rounded-3xl p-8 card-shadow border border-slate-100 flex flex-col fade-in" style="animation-delay: 0.4s">
                <div class="mb-6">
                    <span class="px-3 py-1 bg-blue-50 text-blue-700 text-[10px] font-bold rounded-full uppercase tracking-wider">
                        Nueva Traducción Viviente
                    </span>
                </div>
                <div class="flex-grow">
                    <p id="texto-ntv" class="serif text-xl text-slate-700 leading-relaxed italic">
                        "..."
                    </p>
                </div>
                <div class="mt-8 pt-6 border-t border-slate-50">
                    <p id="cita-ntv" class="font-bold text-slate-400 text-sm tracking-widest uppercase">
                        -
                    </p>
                </div>
            </div>
        </div>

        <!-- Botón de Copiar -->
        <div class="mt-10 text-center fade-in" style="animation-delay: 0.6s">
            <button id="copyBtn" class="inline-flex items-center gap-2 bg-slate-900 text-white px-8 py-3 rounded-full hover:bg-black transition-all active:scale-95 shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                <span class="font-medium">Copiar Comparativa</span>
            </button>
            <p id="feedback" class="text-xs text-green-600 mt-3 opacity-0 transition-opacity font-medium">¡Copiado con éxito!</p>
        </div>
    </div>

    <script>
        // Base de datos de Proverbios con ambas versiones
        const proverbios = [
            {
                cita: "Proverbios 3:5",
                rvr: "Fíate de Jehová de todo tu corazón, y no te apoyes en tu propia prudencia.",
                ntv: "Confía en el Señor con todo tu corazón; no dependas de tu propio entendimiento."
            },
            {
                cita: "Proverbios 4:23",
                rvr: "Sobre toda cosa guardada, guarda tu corazón; porque de él mana la vida.",
                ntv: "Sobre todas las cosas cuida tu corazón, porque este determina el rumbo de tu vida."
            },
            {
                cita: "Proverbios 15:1",
                rvr: "La blanda respuesta quita la ira; mas la palabra áspera hace subir el furor.",
                ntv: "La respuesta apacible desvía el enojo, pero las palabras ásperas encienden los ánimos."
            },
            {
                cita: "Proverbios 16:3",
                rvr: "Encomienda a Jehová tus obras, y tus pensamientos serán afirmados.",
                ntv: "Pon todo lo que hagas en manos del Señor, y tus planes tendrán éxito."
            },
            {
                cita: "Proverbios 17:17",
                rvr: "En todo tiempo ama el amigo, y es como un hermano en tiempo de angustia.",
                ntv: "Un amigo es siempre leal, y un hermano nace para ayudar en tiempo de necesidad."
            },
            {
                cita: "Proverbios 18:10",
                rvr: "El nombre de Jehová es torre fuerte; a ella corre el justo, y está a salvo.",
                ntv: "El nombre del Señor es una fortaleza poderosa; los justos corren a él y están a salvo."
            },
            {
                cita: "Proverbios 22:6",
                rvr: "Instruye al niño en su camino, y aun cuando fuere viejo no se apartará de él.",
                ntv: "Dirige a tus hijos por el camino correcto, y cuando sean mayores, no lo abandonarán."
            },
            {
                cita: "Proverbios 16:18",
                rvr: "Antes del quebrantamiento es la soberbia, y antes de la caída la altivez de espíritu.",
                ntv: "El orgullo va delante de la destrucción, y la arrogancia antes de la caída."
            },
            {
                cita: "Proverbios 3:27",
                rvr: "No te niegues a hacer el bien a quien es debido, cuando tuvieres poder para hacerlo.",
                ntv: "No dejes de hacer el bien a todo el que lo merece, cuando esté a tu alcance ayudarlos."
            },
            {
                cita: "Proverbios 27:17",
                rvr: "Como el hierro con hierro se aguza, así el hombre aguza el rostro de su amigo.",
                ntv: "Como el hierro se afila con hierro, así un amigo se afila con un amigo."
            }
        ];

        function init() {
            const now = new Date();
            // Semilla por fecha (Día, Mes, Año) para que sea fijo todo el día
            const seed = (now.getDate() * 7) + (now.getMonth() * 31) + now.getFullYear();
            
            const index = seed % proverbios.length;
            const item = proverbios[index];

            // Renderizar textos
            document.getElementById('texto-rvr').innerText = `"${item.rvr}"`;
            document.getElementById('cita-rvr').innerText = item.cita;
            
            document.getElementById('texto-ntv').innerText = `"${item.ntv}"`;
            document.getElementById('cita-ntv').innerText = item.cita;

            // Formatear fecha
            const options = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
            document.getElementById('fecha-actual').innerText = now.toLocaleDateString('es-ES', options);

            // Copiar al portapapeles
            document.getElementById('copyBtn').addEventListener('click', () => {
                const shareText = `Proverbio de hoy (${item.cita}):\n\n📖 RVR1960: ${item.rvr}\n\n✨ NTV: ${item.ntv}`;
                
                const el = document.createElement('textarea');
                el.value = shareText;
                document.body.appendChild(el);
                el.select();
                document.execCommand('copy');
                document.body.removeChild(el);

                const fb = document.getElementById('feedback');
                fb.style.opacity = '1';
                setTimeout(() => fb.style.opacity = '0', 2000);
            });
        }

        window.onload = init;
    </script>
</body>
</html>
